{
    "version": "0.2.0",
    "configurations": [

        {
            "name": "CSX Debug",
            "type": "coreclr",
            "request": "launch",
            "program": "${env:HOME}/.dotnet/tools/dotnet-script",
            "args": [
                "${file}",
                "--debug"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false
        },
        {
            "name": "Window CSX Debug",
            "type": "coreclr",
            "request": "launch",
            "program": "dotnet-script",
            "args": [
                "${file}",
                "--debug"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false
        },
        {
            "name": "Python: Current File (.venv)",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/OpenCVStudyForPython/.venv/bin/python",
            "justMyCode": true
        }
    ]
}