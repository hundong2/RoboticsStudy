{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "CSX Debug",
            "type": "coreclr",
            "request": "launch",
            "program": "${env:HOME}/.dotnet/tools/dotnet-script",
            "args": [
                "${file}",
                "--debug"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false
        }
    ]
}